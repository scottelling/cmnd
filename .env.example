# ── CMND environment ──
# Copy to .env.local for local dev, and set the same vars in the Vercel project
# (Production + Preview). Never commit .env.local.

# Server-only. Held by the /api/chat serverless proxy; must NOT have a VITE_ prefix
# (anything VITE_* is bundled into the client). Get one from console.anthropic.com.
ANTHROPIC_API_KEY=

# Client-safe (shipped to the browser). From your Supabase project settings → API.
# Optional today: the app runs local-first (localStorage) without these. Set them
# to enable Supabase-backed cross-device sync once sign-in is wired.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only, optional. Only needed if a serverless function ever performs
# elevated writes that bypass row-level security. Not used by the app today.
SUPABASE_SERVICE_ROLE_KEY=
